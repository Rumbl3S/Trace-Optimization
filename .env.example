# Anthropic API key — required for all agents (haiku, opus, tool_agent)
# Get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key — only needed if sentence-transformers is not installed
# Used as fallback embedder (text-embedding-3-small)
# Get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
